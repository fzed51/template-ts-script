{
  "name": "template-ts-script",
  "packageManager": "yarn@4.9.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "22",
    "jest": "^30.3.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/*.js",
